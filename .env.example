# ═══════════════════════════════════════════════════════════
# FAZZA AUTOMATION — Variáveis de Ambiente v3.0
# ═══════════════════════════════════════════════════════════

# ─── INSTAGRAM OAUTH ───────────────────────────────────────
# Configurar em https://developers.facebook.com/
INSTAGRAM_APP_ID=seu_app_id_aqui
INSTAGRAM_APP_SECRET=seu_app_secret_aqui
INSTAGRAM_REDIRECT_URI=http://localhost:8000/callback

# ─── BANCO DE DADOS ────────────────────────────────────────
# SQLite (desenvolvimento): sqlite:///./automation.db
# PostgreSQL (produção): postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./automation.db

# ─── FASTAPI ───────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=True

# ─── AUTENTICAÇÃO ──────────────────────────────────────────
# Gerar com: openssl rand -hex 32
API_KEY=sua_api_key_secreta_aqui_mude_em_producao

# ─── CORS ──────────────────────────────────────────────────
# Domínios permitidos separados por vírgula
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173

# ─── LOGGING ───────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── RATE LIMITING ─────────────────────────────────────────
# Limites de requisições (requests/hour)
RATE_LIMIT_GLOBAL=1000/hour
RATE_LIMIT_PUBLISH=100/hour
RATE_LIMIT_BATCH=20/hour

# ─── SCHEDULER ─────────────────────────────────────────────
# Timezone para agendamento
SCHEDULER_TIMEZONE=America/Sao_Paulo
# Intervalo de verificação de posts agendados (segundos)
SCHEDULER_CHECK_INTERVAL=60

# ─── RETRY LOGIC ───────────────────────────────────────────
# Número máximo de tentativas para publicar
MAX_PUBLISH_RETRIES=3
# Delays entre retries em segundos (separados por vírgula)
RETRY_DELAYS=2,5,10
