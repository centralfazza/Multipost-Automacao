# ── Database ──────────────────────────────────────────────────────────────────
# Supabase / PostgreSQL (production)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Instagram / Facebook ──────────────────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://your-domain.com/channels/instagram/callback

# ── TikTok ────────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://your-domain.com/channels/tiktok/callback

# ── YouTube / Google ──────────────────────────────────────────────────────────
# (YouTube channels are connected via OAuth — store tokens in Channel.access_token)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://your-domain.com/channels/youtube/callback

# ── Twitter / X ───────────────────────────────────────────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=https://your-domain.com/channels/twitter/callback

# ── LinkedIn ──────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://your-domain.com/channels/linkedin/callback
