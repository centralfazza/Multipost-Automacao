# ═══════════════════════════════════════════════════════════
# FAZZA AUTOMATION — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════

# ─── INSTAGRAM OAUTH ───────────────────────────────────────
# Configurar em https://developers.facebook.com/
INSTAGRAM_APP_ID=seu_app_id_aqui
INSTAGRAM_APP_SECRET=seu_app_secret_aqui
INSTAGRAM_REDIRECT_URI=http://localhost:8000/callback

# ─── BANCO DE DADOS ────────────────────────────────────────
# SQLite (desenvolvimento): /tmp/automation.db
# PostgreSQL (produção): postgresql://user:password@host:5432/dbname
DATABASE_PATH=/tmp/automation.db

# ─── FLASK/FASTAPI ────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=sua_chave_secreta_aqui_troque_em_producao
DEBUG=True

# ─── AUTENTICAÇÃO ──────────────────────────────────────────
API_KEY=sua_api_key_secreta_aqui_mude_em_producao

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── LOGGING ───────────────────────────────────────────────
LOG_LEVEL=INFO
