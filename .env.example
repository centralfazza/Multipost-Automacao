# ── Database ──────────────────────────────────────────────────────────────────
# Neon Postgres (recomendado no Vercel — grátis)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Vercel Cron (protege o endpoint /cron/publish-scheduled) ─────────────────
CRON_SECRET=qualquer-string-secreta-aqui

# ── Vercel Blob (upload de mídia) ─────────────────────────────────────────────
# Crie em: vercel.com → Storage → Create → Blob
BLOB_READ_WRITE_TOKEN=

# ── Instagram / Facebook (mesmo app Meta) ─────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://seu-dominio.vercel.app/channels/instagram/callback
FACEBOOK_REDIRECT_URI=https://seu-dominio.vercel.app/oauth/facebook/callback

# ── TikTok ────────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://seu-dominio.vercel.app/channels/tiktok/callback

# ── YouTube / Google ──────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://seu-dominio.vercel.app/oauth/youtube/callback

# ── Twitter / X ───────────────────────────────────────────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=https://seu-dominio.vercel.app/oauth/twitter/callback

# ── LinkedIn ──────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://seu-dominio.vercel.app/oauth/linkedin/callback
